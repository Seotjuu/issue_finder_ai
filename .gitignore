# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Python virtual environments
/backend/venv
/venv
.venv

# Trained ML models (large binary files — keep folder structure via .gitkeep)
# 주의: Railway 배포를 위해 saved_models는 git에 포함 필요
# 파일 크기가 100MB 초과 시 Git LFS 사용 필요
/backend/saved_models/*.keras
/backend/saved_models/*.h5
/backend/saved_models/mlp.pkl
/backend/saved_models/complementnb.pkl

# Dataset (issues.json은 배포에 필요하므로 git에 포함)

# Python cache
**/__pycache__/
*.pyc
*.pyo

# Frontend dependencies
/frontend/node_modules
/node_modules

# Next.js build output
/frontend/.next/
.next/
/frontend/out/
/out/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

